// --- BASE FIXA COM NICHO PARA GAVETA ---
d_externo = 207; 
h_base = 35; 
esp = 3; 
folga = 1.5;

difference() {
    // Corpo da base
    cylinder(h = h_base, d = d_externo + esp*2 + folga, $fn=120);
    
    // Cavidade do carrossel
    translate([0, 0, h_base - 15]) 
        cylinder(h = 20, d = d_externo + folga, $fn=120);

    // Nicho da gaveta
    translate([d_externo/2 - 30, -25, -1])
        cube([60, 50, h_base - 10]); 

    // Canal de queda inclinado
    rotate([0, 0, -10])
    translate([35, -20, h_base - 18]) 
    rotate([0, 20, 0]) 
        cube([d_externo/2 + 10, 40, 30]);

    // Furo do motor
    translate([0,0,-1])
        cylinder(h = 40, d = 10, center = true, $fn=50);
}


