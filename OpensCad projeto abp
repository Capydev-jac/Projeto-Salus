d_externo = 207; 
esp = 3;

difference() {
    cylinder(h=8, d=d_externo + esp*4, $fn=120); // Topo
    translate([0,0,-1]) 
        cylinder(h=6, d=d_externo + esp*2 + 1.5, $fn=120); // Encaixe
}


