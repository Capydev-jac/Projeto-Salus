// --- GAVETA COLETORA ---
h_base = 35; 
esp = 2.5;

union() {
    difference() {
        // Corpo da gaveta
        cube([55, 45, h_base - 15], center=true);
        // Interior oco
        translate([0, 0, esp])
            cube([55 - esp*2, 45 - esp*2, h_base], center=true);
    }
    // Puxador externo
    translate([27.5, -10, - (h_base - 15)/2])
        cube([10, 20, h_base - 15]);
}

