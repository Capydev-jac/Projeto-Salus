// --- CARROSSEL DE 21 DIVISÕES ---
d_externo = 207; 
d_interno = 70;  
h_carrossel = 50; 
esp = 2;

union() {
    // Paredes circulares
    difference() {
        cylinder(h=h_carrossel, d=d_externo, $fn=100);
        translate([0,0,-1]) cylinder(h=h_carrossel+2, d=d_externo-esp*2, $fn=100);
    }
    // Núcleo com encaixe D-Shaft para o motor
    difference() {
        cylinder(h=h_carrossel, d=d_interno, $fn=100);
        translate([0,0,-1]) intersection() {
            cylinder(h=h_carrossel+2, d=5.5, $fn=50); // Diâmetro do eixo
            cube([5.5, 3.5, h_carrossel+2], center=true); // Achatado do eixo
        }
    }
    // 21 Divisórias
    for (i = [0 : 20]) {
        rotate([0, 0, i * (360/21)])
            translate([d_interno/2, -esp/2, 0])
                cube([(d_externo-d_interno)/2, esp, h_carrossel]);
    }
}




